# ADK env
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
CODE_INTERPRETER_EXTENSION_NAME=projects/your-project-number/locations/us-central1/extensions/your-extension-id

# OAuth credentials for per-user passthrough auth (BigQuery + Data Agent toolsets).
# Each user authenticates via Google OAuth consent screen on first tool call;
# tokens are cached in their ADK session and refreshed automatically.
#
# Setup:
#   1. Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   2. Application type: Web application
#   3. Add authorised redirect URIs:
#      - Local ADK web UI: http://localhost:8000/oauth2callback
#      - Agent Engine / Gemini Enterprise:
#          https://vertexaisearch.cloud.google.com/oauth-redirect
#          https://vertexaisearch.cloud.google.com/static/oauth/oauth.html
#   4. Download JSON and copy client_id / client_secret below
#
# Required scopes (handled automatically by ADK):
#   https://www.googleapis.com/auth/bigquery
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Agent Engine deployment
GCS_STAGING_BUCKET=gs://your-bucket-name
AGENT_ENGINE_DISPLAY_NAME=BigQuery Multi-Agent App

# Set after running deployment/deploy.py:
AGENT_ENGINE_RESOURCE_NAME=

# Gemini Enterprise (Agentspace) registration
# Found in the Gemini Enterprise console under your app settings.
GEMINI_ENTERPRISE_APP_ID=your-gemini-enterprise-app-id
AGENT_DISPLAY_NAME=BigQuery Multi-Agent App

# BQML Agent configuration
BQML_RAG_CORPUS_NAME=
