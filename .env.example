# ============================================================
# BigQuery Multi-Agent App — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Do NOT set GOOGLE_APPLICATION_CREDENTIALS — use ADC instead:
#   gcloud auth application-default login

# --- Core (required to run) ---
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION is intentionally absent from this file.
# Agent Engine docs state it should not be set as a deployment env var.
# Instead, constants.py sets os.environ["GOOGLE_CLOUD_LOCATION"] = "global" at
# runtime so the google.genai.Client routes model calls to the Vertex AI global
# endpoint (https://aiplatform.googleapis.com/), which is required for Gemini 3
# models. Sessions and memory use GOOGLE_CLOUD_AGENT_ENGINE_LOCATION, set
# internally by the AdkApp template from the deployment region.
#
# Agent Engine deployment region — used by deploy.sh (--region flag) only.
# Must be a real GCP region (e.g. us-central1). Not forwarded to the container.
AGENT_ENGINE_REGION=us-central1

# --- OAuth 2.0 credentials (required) ---
# Each user authenticates via OAuth consent screen on first tool call.
# Setup:
#   1. Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   2. Application type: Web application
#   3. Authorised redirect URIs:
#      - Local:              http://localhost:8000/oauth2callback
#      - Gemini Enterprise:  https://vertexaisearch.cloud.google.com/oauth-redirect
#                            https://vertexaisearch.cloud.google.com/static/oauth/oauth.html
#   4. Copy client_id and client_secret below
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# --- Code Interpreter Extension (required for DS agent) ---
# Create once: uv run python setup/vertex_extensions/setup_vertex_extensions.py
CODE_INTERPRETER_EXTENSION_NAME=projects/your-project-number/locations/us-central1/extensions/your-extension-id

# --- BQML RAG corpus (required for BQML agent) ---
# Created by: uv run python setup/rag_corpus/create_bqml_corpus.py
# (script writes BQML_RAG_CORPUS_NAME here automatically)
# RAG_LOCATION defaults to us-west4 (higher quota than us-central1 for new projects).
# Override only if your project has RAG quota in another region.
# RAG_LOCATION=us-west4
BQML_RAG_CORPUS_NAME=

# --- Set after deploying to Agent Engine (deployment/deploy.sh) ---
# These are written here automatically by deploy.sh after a successful deployment.
# AGENT_ENGINE_RESOURCE_NAME=projects/your-project-number/locations/us-central1/reasoningEngines/your-engine-id
# AGENT_ENGINE_ID is the numeric suffix of AGENT_ENGINE_RESOURCE_NAME.
# Example: "projects/123/locations/us-central1/reasoningEngines/456789" → 456789
# Used for local Memory Bank: adk web --memory_service_uri=agentengine://$AGENT_ENGINE_ID
# AGENT_ENGINE_ID=your-engine-id

# --- Telemetry (optional, Agent Engine only) ---
# Enables the observability dashboard (traces + logs). Does NOT capture prompt content.
# Requires APIs: gcloud services enable telemetry.googleapis.com logging.googleapis.com
# GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
# Enables logging of full prompt inputs and response outputs.
# WARNING: May capture PII. Ensure data handling policies are in place before enabling.
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# --- Gemini Enterprise registration (deployment/register_gemini_enterprise.sh) ---
# Found in Gemini Enterprise console → your app settings.
GEMINI_ENTERPRISE_APP_ID=your-gemini-enterprise-app-id
# Display name shown in Gemini Enterprise (optional, defaults to "BigQuery Multi-Agent App")
AGENT_DISPLAY_NAME="BigQuery Multi-Agent App"
# Gemini Enterprise endpoint location: us, eu, or global (defaults to us)
# GEMINI_ENTERPRISE_ENDPOINT_LOCATION=us
