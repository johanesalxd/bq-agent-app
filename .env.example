# ADK env
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
CODE_INTERPRETER_EXTENSION_NAME=projects/your-project-number/locations/us-central1/extensions/your-extension-id

# BigQuery tools use Application Default Credentials (ADC) directly.
# Run: gcloud auth application-default login
# No TOOLBOX_URL or BIGQUERY_PROJECT needed.

# Agent Engine deployment
GCS_STAGING_BUCKET=gs://your-bucket-name

# BQML Agent configuration
BQML_RAG_CORPUS_NAME=
